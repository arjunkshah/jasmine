# API keys for Jasmine — add at least one
# Get Groq key: https://console.groq.com/
# Get Gemini key: https://aistudio.google.com/apikey
# E2B (for Next.js deploy): https://e2b.dev/dashboard

VITE_GROQ_API_KEY=
VITE_GEMINI_API_KEY=
E2B_API_KEY=

# Optional: custom E2B template with Next.js pre-installed (faster, fewer 504s)
# 1. Build: npm run e2b:build
# 2. Set E2B_TEMPLATE_ID to the template ID shown (e.g. jasmine-nextjs)
E2B_TEMPLATE_ID=

# Firebase (optional — for project storage and auth)
# Create project at https://console.firebase.google.com/
# Enable Firebase Auth (Email/Password + Google) and Firestore
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
