# API keys for Jasmine — add at least one for text
# Get Groq key: https://console.groq.com/
# Get Gemini key: https://aistudio.google.com/apikey
# Vercel AI Gateway: https://vercel.com/ai-gateway — Kimi K2.5, GPT 5.4, image gen (no client keys)
# IMAGES: AI_GATEWAY_API_KEY (preferred) or GEMINI_API_KEY for {{IMAGE:...}}
# E2B (for Next.js deploy): https://e2b.dev/dashboard

VITE_GROQ_API_KEY=
VITE_GEMINI_API_KEY=
AI_GATEWAY_API_KEY=
E2B_API_KEY=

# Optional: custom E2B template with Node + Vite (fixes "no service on port 5173")
# Base template may not have Node. Build: npm run e2b:build, then set E2B_TEMPLATE_ID=jasmine-vite
E2B_TEMPLATE_ID=

# Web search (for Search button — agent-style context). Add one:
# Serper: 2500 free/mo at https://serper.dev
# Tavily: free tier at https://tavily.com
SERPER_API_KEY=
# TAVILY_API_KEY=

# Netlify (for Deploy button — deploys built site to netlify.app)
# Get token: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=

# GitHub (for Push to GitHub button — creates repo and pushes code)
# Get token: https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=

# Firebase (optional — for project storage and auth)
# Create project at https://console.firebase.google.com/
# Enable Firebase Auth (Email/Password + Google) and Firestore
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Analytics (optional — enable in Firebase Console, add measurementId from Project settings)
VITE_FIREBASE_MEASUREMENT_ID=

# Share invites (email)
# Get key at https://resend.com — verify domain for production
RESEND_API_KEY=re_feAsCGue_FWB2iDgADNdUgtSd5DkKUj7J
# Optional: custom from address (e.g. Jasmine <noreply@yourdomain.com>)
# RESEND_FROM=

# Admin dashboard (tasks + projects)
# VITE_ADMIN_PASSWORD: password for /admin (default: zerotone)
# VITE_ADMIN_PASSWORD=zerotone
# FIREBASE_SERVICE_ACCOUNT: JSON string from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as one line, or use GOOGLE_APPLICATION_CREDENTIALS pointing to the file path
FIREBASE_SERVICE_ACCOUNT=
# ADMIN_API_KEY: secret for create/update/delete tasks and viewing projects. Enter in Admin UI or send as x-admin-key header.
ADMIN_API_KEY=
