# API keys for Jasmine — add at least one for text
# Get Groq key: https://console.groq.com/
# Get Gemini key: https://aistudio.google.com/apikey
# IMAGES: Add GEMINI_API_KEY (server-only, recommended) or VITE_GEMINI_API_KEY in Vercel env for {{IMAGE:...}}
# E2B (for Next.js deploy): https://e2b.dev/dashboard

VITE_GROQ_API_KEY=
VITE_GEMINI_API_KEY=
E2B_API_KEY=

# Optional: custom E2B template with Node + Vite (fixes "no service on port 5173")
# Base template may not have Node. Build: npm run e2b:build, then set E2B_TEMPLATE_ID=jasmine-vite
E2B_TEMPLATE_ID=

# Netlify (for Deploy button — deploys built site to netlify.app)
# Get token: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=

# Firebase (optional — for project storage and auth)
# Create project at https://console.firebase.google.com/
# Enable Firebase Auth (Email/Password + Google) and Firestore
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
