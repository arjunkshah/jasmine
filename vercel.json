{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/sandbox/start.js": { "maxDuration": 60 },
    "api/sandbox/update.js": { "maxDuration": 60 },
    "api/deploy.js": { "maxDuration": 120 }
  }
}
