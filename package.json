{
  "name": "jasmine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx server.ts",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:all": "npm run dev",
    "e2b:build": "echo 'Starting E2B build...' && npx tsx e2b-template/build.mts",
    "test:server": "node scripts/test-server.mjs",
    "test:api": "node scripts/test-api.mjs",
    "test:api:deployed": "node scripts/test-api.mjs --deployed",
    "tasks:fetch": "node scripts/fetch-tasks.mjs",
    "test:generate": "node scripts/test-generation.mjs",
    "test:generate:verbose": "VERBOSE=1 node scripts/test-generation.mjs",
    "firebase:deploy": "firebase deploy --only firestore",
    "postinstall": "node scripts/patch-babel-types.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@google/genai": "^1.43.0",
    "ai": "^6.0.116",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "e2b": "^2.13.0",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "form-data": "^4.0.5",
    "framer-motion": "^12.34.3",
    "jszip": "^3.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^4.7.0",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "vite": "^7.3.1",
    "vite-express": "^0.22.1"
  }
